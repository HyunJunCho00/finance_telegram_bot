# Core
# PROJECT_ID is optional on GCP VM (auto-detected from metadata when USE_SECRET_MANAGER=true)
PROJECT_ID=
REGION=asia-northeast3
VERTEX_REGION=us-central1
BOOT_DISK_SIZE_GB=50
BOOT_DISK_TYPE=pd-balanced
USE_SECRET_MANAGER=false

# Supabase — Project 1: 수치 데이터 (market, funding, cvd, liquidations, microstructure, deribit, fear_greed, macro)
SUPABASE_URL_QUANT=
SUPABASE_KEY_QUANT=

# Supabase — Project 2: 텍스트/AI 데이터 (telegram, narrative, ai_reports, evaluations, trade_executions 등)
SUPABASE_URL_TEXT=
SUPABASE_KEY_TEXT=

# Exchanges
BINANCE_API_KEY=
BINANCE_API_SECRET=
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# Telegram
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI / Narrative
PERPLEXITY_API_KEY=
# LightRAG backends
#NEO4J_URI=neo4j+s://{Username}.databases.neo4j.io
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
MILVUS_URI=
MILVUS_TOKEN=

# Optional
GCS_ARCHIVE_BUCKET=
ENABLE_GCS_ARCHIVE=false
ENABLE_DIRECT_MCP_TRADING=false

# Macro (FRED)
FRED_API_KEY=

# Dune
DUNE_API_KEY=
DUNE_ENABLED=false
DUNE_BUDGET_GUARD=true
DUNE_GLOBAL_MIN_INTERVAL_MINUTES=360
DUNE_MAX_QUERY_RUNS_PER_DAY=8
DUNE_MAX_QUERIES_PER_RUN=1
DUNE_PRIORITY_QUERY_IDS=21689,4319,6638261

# Deploy
REPO_URL=https://github.com/<your-org>/finance_telegram_bot.git

# GCP Account Migration (계정 이전 시에만 설정, 평소엔 비워둠)
# OLD_GCS_BUCKET=이전-프로젝트의-버킷-이름
# OLD_PROJECT_ID=이전-프로젝트-ID (로그용, 필수 아님)

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_API_KEY_JUDGE=
GEMINI_API_KEY_VLM=
GROQ_API_KEY=
CEREBRAS_API_KEY=
