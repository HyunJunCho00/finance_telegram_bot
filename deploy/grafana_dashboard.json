{
  "title": "Crypto Trading Bot",
  "uid": "crypto-trading-bot",
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {"id":1,"title":"Bot 상태 (execution)","type":"stat","gridPos":{"h":4,"w":3,"x":0,"y":0},
      "targets":[{"expr":"up{job=\"execution\"}","legendFormat":"execution"}],
      "fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}]}}},
    {"id":2,"title":"Bot 상태 (scheduler)","type":"stat","gridPos":{"h":4,"w":3,"x":3,"y":0},
      "targets":[{"expr":"up{job=\"scheduler\"}","legendFormat":"scheduler"}],
      "fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}]}}},
    {"id":3,"title":"BTC 포지션","type":"stat","gridPos":{"h":4,"w":3,"x":6,"y":0},
      "targets":[{"expr":"position_side{symbol=\"BTCUSDT\"}"}],
      "fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{"1":{"text":"LONG","color":"green"},"-1":{"text":"SHORT","color":"red"},"0":{"text":"FLAT","color":"gray"}}}]}}},
    {"id":4,"title":"ETH 포지션","type":"stat","gridPos":{"h":4,"w":3,"x":9,"y":0},
      "targets":[{"expr":"position_side{symbol=\"ETHUSDT\"}"}],
      "fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{"1":{"text":"LONG","color":"green"},"-1":{"text":"SHORT","color":"red"},"0":{"text":"FLAT","color":"gray"}}}]}}},
    {"id":5,"title":"BTC 미실현 PnL","type":"stat","gridPos":{"h":4,"w":3,"x":12,"y":0},
      "targets":[{"expr":"position_unrealized_pnl_usd{symbol=\"BTCUSDT\"}"}],
      "fieldConfig":{"defaults":{"unit":"currencyUSD","thresholds":{"steps":[{"color":"red","value":-9999999},{"color":"green","value":0}]}}}},
    {"id":6,"title":"ETH 미실현 PnL","type":"stat","gridPos":{"h":4,"w":3,"x":15,"y":0},
      "targets":[{"expr":"position_unrealized_pnl_usd{symbol=\"ETHUSDT\"}"}],
      "fieldConfig":{"defaults":{"unit":"currencyUSD","thresholds":{"steps":[{"color":"red","value":-9999999},{"color":"green","value":0}]}}}},
    {"id":7,"title":"Outbox 실패","type":"stat","gridPos":{"h":4,"w":3,"x":18,"y":0},
      "targets":[{"expr":"outbox_published_total{status=\"failed\"}"}],
      "fieldConfig":{"defaults":{"thresholds":{"steps":[{"color":"green","value":0},{"color":"red","value":1}]}}}},
    {"id":8,"title":"Job 에러","type":"stat","gridPos":{"h":4,"w":3,"x":21,"y":0},
      "targets":[{"expr":"sum(scheduler_job_results_total{result=\"error\"})","legendFormat":"에러 누적"}],
      "fieldConfig":{"defaults":{"thresholds":{"steps":[{"color":"green","value":0},{"color":"red","value":1}]}}}},

    {"id":10,"title":"Judge 판단 분포 (누적)","type":"piechart","gridPos":{"h":8,"w":8,"x":0,"y":4},
      "targets":[
        {"expr":"sum by (action) (judge_decisions_total)","legendFormat":"{{action}}"}
      ]},
    {"id":11,"title":"Judge 판단 추이 (건/시간)","type":"timeseries","gridPos":{"h":8,"w":16,"x":8,"y":4},
      "targets":[
        {"expr":"rate(judge_decisions_total{action=\"LONG\"}[1h]) * 3600","legendFormat":"LONG"},
        {"expr":"rate(judge_decisions_total{action=\"SHORT\"}[1h]) * 3600","legendFormat":"SHORT"},
        {"expr":"rate(judge_decisions_total{action=\"HOLD\"}[1h]) * 3600","legendFormat":"HOLD"}
      ]},

    {"id":12,"title":"Orchestrator 실행 시간","type":"timeseries","gridPos":{"h":8,"w":12,"x":0,"y":12},
      "targets":[
        {"expr":"histogram_quantile(0.50, rate(orchestrator_run_duration_seconds_bucket[1h]))","legendFormat":"p50"},
        {"expr":"histogram_quantile(0.95, rate(orchestrator_run_duration_seconds_bucket[1h]))","legendFormat":"p95"}
      ],"fieldConfig":{"defaults":{"unit":"s"}}},
    {"id":13,"title":"Orchestrator 성공/실패","type":"timeseries","gridPos":{"h":8,"w":12,"x":12,"y":12},
      "targets":[
        {"expr":"rate(scheduler_job_results_total{job=\"daily_precision\",result=\"success\"}[1h]) * 3600","legendFormat":"daily precision 성공"},
        {"expr":"rate(scheduler_job_results_total{job=\"daily_precision\",result=\"error\"}[1h]) * 3600","legendFormat":"daily precision 에러"},
        {"expr":"rate(scheduler_job_results_total{job=\"hourly_monitor\",result=\"success\"}[1h]) * 3600","legendFormat":"hourly monitor 성공"},
        {"expr":"rate(scheduler_job_results_total{job=\"hourly_monitor\",result=\"error\"}[1h]) * 3600","legendFormat":"hourly monitor 에러"}
      ]},

    {"id":14,"title":"Telegram → LightRAG ingest (건/시간)","type":"timeseries","gridPos":{"h":8,"w":12,"x":0,"y":20},
      "targets":[
        {"expr":"rate(tg_lightrag_ingested_total[1h]) * 3600","legendFormat":"{{category}}"},
        {"expr":"rate(tg_no_signal_total[1h]) * 3600","legendFormat":"NO_SIGNAL (스킵)"}
      ]},
    {"id":15,"title":"Job 처리 시간 (p95)","type":"timeseries","gridPos":{"h":8,"w":12,"x":12,"y":20},
      "targets":[
        {"expr":"histogram_quantile(0.95, rate(scheduler_job_duration_seconds_bucket[1h]))","legendFormat":"{{job}}"}
      ],"fieldConfig":{"defaults":{"unit":"s"}}},

    {"id":16,"title":"미실현 PnL 추이","type":"timeseries","gridPos":{"h":8,"w":12,"x":0,"y":28},
      "targets":[
        {"expr":"position_unrealized_pnl_usd{symbol=\"BTCUSDT\"}","legendFormat":"BTC"},
        {"expr":"position_unrealized_pnl_usd{symbol=\"ETHUSDT\"}","legendFormat":"ETH"}
      ],"fieldConfig":{"defaults":{"unit":"currencyUSD"}}},
    {"id":17,"title":"메모리 / CPU","type":"timeseries","gridPos":{"h":8,"w":12,"x":12,"y":28},
      "targets":[
        {"expr":"process_resident_memory_bytes{job=\"scheduler\"}","legendFormat":"scheduler RSS"},
        {"expr":"process_resident_memory_bytes{job=\"execution\"}","legendFormat":"execution RSS"}
      ],"fieldConfig":{"defaults":{"unit":"bytes"}}},

    {"id":20,"title":"Judge 승률 추정 (%)","type":"timeseries","gridPos":{"h":8,"w":8,"x":0,"y":36},
      "description":"Judge가 마지막 사이클에서 계산한 승률. 50% 이하가 반복되면 prompt 또는 시장 국면 점검.",
      "targets":[
        {"expr":"judge_win_probability_pct{symbol=\"BTCUSDT\"}","legendFormat":"BTC"},
        {"expr":"judge_win_probability_pct{symbol=\"ETHUSDT\"}","legendFormat":"ETH"}
      ],"fieldConfig":{"defaults":{"unit":"percent","min":0,"max":100,"thresholds":{"steps":[{"color":"red","value":0},{"color":"yellow","value":45},{"color":"green","value":55}]}}}},
    {"id":21,"title":"Judge EV (기대값)","type":"timeseries","gridPos":{"h":8,"w":8,"x":8,"y":36},
      "description":"양수=기대수익 > 기대손실. 0 근처 반복 시 리스크/리워드 세팅 검토.",
      "targets":[
        {"expr":"judge_ev{symbol=\"BTCUSDT\"}","legendFormat":"BTC EV"},
        {"expr":"judge_ev{symbol=\"ETHUSDT\"}","legendFormat":"ETH EV"}
      ],"fieldConfig":{"defaults":{"custom":{"lineWidth":2},"thresholds":{"steps":[{"color":"red","value":-999},{"color":"green","value":0}]}}}},
    {"id":22,"title":"Judge 배분율 (%)","type":"timeseries","gridPos":{"h":8,"w":8,"x":16,"y":36},
      "description":"최종 allocation_pct. HOLD=0. 너무 크면 Kelly 과도; 너무 작으면 PolicyEngine 과도 축소.",
      "targets":[
        {"expr":"judge_allocation_pct{symbol=\"BTCUSDT\"}","legendFormat":"BTC alloc"},
        {"expr":"judge_allocation_pct{symbol=\"ETHUSDT\"}","legendFormat":"ETH alloc"}
      ],"fieldConfig":{"defaults":{"unit":"percent","min":0}}},

    {"id":23,"title":"Paper 슬리피지 분포 (bps)","type":"histogram","gridPos":{"h":8,"w":12,"x":0,"y":44},
      "description":"Paper trade 체결 슬리피지. 실제 거래 비용 모델 검증용. 1bps = 0.01%.",
      "targets":[
        {"expr":"rate(trade_slippage_bps_bucket[1h])","legendFormat":"{{exchange}} {{side}}"}
      ],"fieldConfig":{"defaults":{"unit":"short"}}},
    {"id":24,"title":"Outbox 적체 시간 (초)","type":"timeseries","gridPos":{"h":8,"w":12,"x":12,"y":44},
      "description":"가장 오래된 PENDING 이벤트 경과 시간. 300초 이상이면 dispatcher 지연 또는 반복 실패.",
      "targets":[
        {"expr":"outbox_oldest_pending_age_seconds","legendFormat":"oldest pending age"}
      ],"fieldConfig":{"defaults":{"unit":"s","thresholds":{"steps":[{"color":"green","value":0},{"color":"yellow","value":120},{"color":"red","value":300}]}}}},

    {"id":25,"title":"채널별 메시지 수신량 (건/시간)","type":"timeseries","gridPos":{"h":8,"w":24,"x":0,"y":52},
      "description":"채널별 메시지 유입 속도. 특정 채널이 조용해지면 신호 편향 발생 가능.",
      "targets":[
        {"expr":"rate(tg_channel_messages_total[1h]) * 3600","legendFormat":"{{channel}}"}
      ]}
  ],
  "schemaVersion":38,
  "version":4
}
